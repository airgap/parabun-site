{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "displayName": "Parabun Keyword Injection",
  "name": "parabun-inject",
  "scopeName": "inject.parabun-keywords",
  "injectTo": ["source.pts", "source.ptsx", "source.pjs", "source.pjsx"],
  "injectionSelector": "L:source.pts -comment -string, L:source.ptsx -comment -string, L:source.pjs -comment -string, L:source.pjsx -comment -string",
  "patterns": [
    {
      "match": "\\b(fun)\\b(?=\\s*[a-zA-Z_$*(<])",
      "captures": { "1": { "name": "storage.type.function.parabun" } }
    },
    {
      "match": "\\b(export)\\s+(pure)\\s+(async)\\s+(fun(?:ction)?)\\b",
      "captures": {
        "1": { "name": "keyword.control.export" },
        "2": { "name": "keyword.other.pure.parabun" },
        "3": { "name": "storage.modifier.async" },
        "4": { "name": "storage.type.function.parabun" }
      }
    },
    {
      "match": "\\b(export)\\s+(pure)\\s+(fun(?:ction)?)\\b",
      "captures": {
        "1": { "name": "keyword.control.export" },
        "2": { "name": "keyword.other.pure.parabun" },
        "3": { "name": "storage.type.function.parabun" }
      }
    },
    {
      "match": "\\b(pure)\\s+(async)\\s+(fun(?:ction)?)\\b",
      "captures": {
        "1": { "name": "keyword.other.pure.parabun" },
        "2": { "name": "storage.modifier.async" },
        "3": { "name": "storage.type.function.parabun" }
      }
    },
    {
      "match": "\\b(pure)\\s+(fun(?:ction)?)\\b",
      "captures": {
        "1": { "name": "keyword.other.pure.parabun" },
        "2": { "name": "storage.type.function.parabun" }
      }
    },
    {
      "match": "\\b(pure)\\s+(async)\\b(?=\\s*(?:\\(|\\w+\\s*=>))",
      "captures": {
        "1": { "name": "keyword.other.pure.parabun" },
        "2": { "name": "storage.modifier.async" }
      }
    },
    {
      "match": "\\b(pure)\\b(?=\\s*(?:\\(|\\w+\\s*=>))",
      "captures": { "1": { "name": "keyword.other.pure.parabun" } }
    },
    {
      "match": "\\b(signal)\\b(?=\\s+[A-Za-z_$][\\w$]*\\s*[=,;:!])",
      "captures": { "1": { "name": "storage.type.signal.parabun" } }
    },
    {
      "match": "\\b(effect)\\b(?=\\s*\\{)",
      "captures": { "1": { "name": "keyword.control.effect.parabun" } }
    },
    {
      "comment": "when EXPR { ... } / when not EXPR { ... } — edge-triggered handler",
      "match": "\\b(when)\\s+(not)\\b",
      "captures": {
        "1": { "name": "keyword.control.when.parabun" },
        "2": { "name": "keyword.control.when.not.parabun" }
      }
    },
    {
      "match": "\\b(when)\\b(?=\\s+[!A-Za-z_$])",
      "captures": { "1": { "name": "keyword.control.when.parabun" } }
    },
    {
      "match": "\\b(arena)\\b(?=\\s*\\{)",
      "captures": { "1": { "name": "keyword.control.arena.parabun" } }
    },
    {
      "match": "\\b(memo)\\s+(async)\\s+(?=[A-Za-z_$][\\w$]*\\s*(?:<|\\())",
      "captures": {
        "1": { "name": "keyword.other.memo.parabun" },
        "2": { "name": "storage.modifier.async" }
      }
    },
    {
      "match": "\\b(memo)\\s+(?!async\\b)(?=[A-Za-z_$][\\w$]*\\s*(?:<|\\())",
      "captures": { "1": { "name": "keyword.other.memo.parabun" } }
    },
    {
      "match": "\\b(memo)\\s+(async)\\s+(?=\\(|[A-Za-z_$][\\w$]*\\s*=>)",
      "captures": {
        "1": { "name": "keyword.other.memo.parabun" },
        "2": { "name": "storage.modifier.async" }
      }
    },
    {
      "match": "\\b(memo)\\s+(?=\\(|<[\\w\\s,=]+>\\s*\\(|[A-Za-z_$][\\w$]*\\s*=>)",
      "captures": { "1": { "name": "keyword.other.memo.parabun" } }
    },
    {
      "match": "\\b(defer)\\b(?=\\s+[A-Za-z_$])",
      "captures": { "1": { "name": "keyword.control.defer.parabun" } }
    },
    {
      "name": "keyword.operator.await-assign.parabun",
      "match": "\\.\\.="
    },
    {
      "name": "keyword.operator.catch.parabun",
      "match": "\\.\\.!"
    },
    {
      "name": "keyword.operator.finally.parabun",
      "match": "\\.\\.&"
    },
    {
      "name": "keyword.operator.range.parabun",
      "match": "\\.\\."
    },
    {
      "name": "keyword.operator.pipeline.parabun",
      "match": "\\|>"
    },
    {
      "name": "keyword.operator.rbind.parabun",
      "match": "~>"
    },
    {
      "name": "keyword.operator.callbind.parabun",
      "match": "(?<![\\-=<])->"
    }
  ]
}
